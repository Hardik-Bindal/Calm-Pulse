# Copy this file to .env.local and fill in values
# For local development, these defaults are used automatically (localhost:5001)

# Set this to your deployed backend URL in Vercel's environment variables
# Example: https://calm-pulse-api.railway.app
REACT_APP_API_URL=

# OAuth Keys (optional - features still work with sample login if not set)
REACT_APP_GOOGLE_CLIENT_ID=
REACT_APP_MICROSOFT_CLIENT_ID=
